# Smart Receipts environment variables
# Copy to .env.local for local development or configure in Vercel project settings.

# Required for all database-backed pages and API routes
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Receipt media migration / hosted storage
# Required if you want to upload local receipt files to Vercel Blob.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token"
