# Smart Receipts environment variables
# Copy to .env.local for local development or configure in Vercel project settings.

# Required for all database-backed pages and API routes
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Receipt media migration / hosted storage
# Required if you want to upload local receipt files to Vercel Blob.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_token"

# OCR provider selection
# local  -> use local tesseract/pdftotext (good for local development)
# worker -> call a remote OCR worker (recommended for Vercel production)
OCR_PROVIDER="local"

# Required when OCR_PROVIDER=worker on the app side
OCR_WORKER_URL="https://your-ocr-worker.example.com/ocr"
OCR_WORKER_TOKEN="shared_secret_token"

# OCR worker runtime
# Use the same shared secret token value on both the app and worker.
OCR_WORKER_PORT="4318"
OCR_WORKER_MAX_BODY_BYTES="1048576"
